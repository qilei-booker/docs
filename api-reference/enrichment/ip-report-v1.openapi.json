              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "msg": {
                      "type": "string",
                      "const": "Invalid API method"
                    },
                    "response_code": {
                      "type": "integer",
                      "const": 405
                    }
                  },
                  "required": [
                    "msg",
                    "response_code"
                  ]
                },
                "examples": {
                  "Example 1": {
                    "summary": "Example 1",
                    "value": {
                      "msg": "Invalid API method",
                      "response_code": 405
                    }
                  }
                }
              }
            }
          },
          "429": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "msg": {
                      "type": "string",
                      "enum": [
                        "Request rate limitation",
                        "Beyond {daily/monthly/total} quotas limitation"
                      ]
                    },
                    "response_code": {
                      "type": "integer",
                      "const": 429
                    }
                  },
                  "required": [
                    "msg",
                    "response_code"
                  ]
                },
                "examples": {
                  "Example 1": {
                    "summary": "Example 1",
                    "value": {
                      "msg": "Request rate limitation",
                      "response_code": 429
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "msg": {
                      "type": "string",
                      "enum": [
                        "System error",
                        "URL Download Fail"
                      ]
                    },
                    "response_code": {
                      "type": "integer",
                      "const": 500
                    }
                  },
                  "required": [
                    "msg",
                    "response_code"
                  ]
                },
                "examples": {
                  "Example 1": {
                    "summary": "Example 1",
                    "value": {
                      "msg": "System error",
                      "response_code": 500
                    }
                  }
                }
              }
            }
          }
        },
        "security": []
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {
      "feeds": {
        "bearerFormat": "JWT",
        "description": "请输入您的 JWT 令牌。您可以调用 /login 接口获取该令牌。",
        "type": "http",
        "scheme": "bearer"
